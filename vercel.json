{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS", "HEAD"]
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "@production_api_url"
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_API_URL": "@production_api_url"
    }
  }
}